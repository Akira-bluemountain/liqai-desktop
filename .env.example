# LiqAI v2 — Public API keys (NO private keys are EVER needed)
#
# These are READ-ONLY or task-registration API keys. None of them can sign
# transactions on your behalf. The app's signing happens exclusively via
# your wallet (MetaMask/WalletConnect) or your session key (held in
# OS keychain via Tauri Stronghold).
#
# SECURITY (docs/security-v2.md S8.1):
#   - NEVER add OPERATOR_PRIVATE_KEY or similar here. LiqAI v2 has no
#     such concept.
#   - Don't commit your actual .env file. This file is only the template.
#   - Prefer per-developer keys; don't share them.

# ── Ethereum RPC ──────────────────────────────────────────────────
# Used by the desktop app to read blockchain state.
# Source: https://alchemy.com (free tier sufficient for personal use)
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Fallback public RPC (no key needed):
#   https://eth.llamarpc.com
#   https://rpc.ankr.com/eth

# ── Wallet integration ─────────────────────────────────────────────
# WalletConnect v2 project ID for mobile wallet support.
# Source: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Smart Account (ZeroDev Kernel) ─────────────────────────────────
# Project ID for ZeroDev's bundler/paymaster (ERC-4337).
# Source: https://dashboard.zerodev.app
NEXT_PUBLIC_ZERODEV_PROJECT_ID=

# ── Automation (Gelato) ────────────────────────────────────────────
# API key for Gelato Automate task registration.
# Source: https://app.gelato.network
NEXT_PUBLIC_GELATO_API_KEY=

# ── Price data (CoinGecko) ─────────────────────────────────────────
# Optional: higher rate limits on the pro tier. Public endpoint works for
# development without a key.
NEXT_PUBLIC_COINGECKO_API_KEY=

# ── Debug logging ──────────────────────────────────────────────────
# When set to "true" the desktop app emits verbose console.info/warn
# about session-key reconciliation, rebalance phases, and bundler gas
# decisions. Leave unset (or "false") for production builds — these
# logs include permission IDs, signer addresses, and gas parameters
# that, while not secrets, make forensics noisier and broaden the
# DevTools-visible surface area.
NEXT_PUBLIC_LIQAI_DEBUG=
